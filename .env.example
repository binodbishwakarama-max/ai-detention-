# ── Application ──────────────────────────────────────────
APP_NAME=eval-engine
APP_ENV=development
APP_DEBUG=false
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4

# ── Security ─────────────────────────────────────────────
SECRET_KEY=change-me-to-a-64-char-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
API_KEY_HEADER=X-API-Key
CORS_ORIGINS=["http://localhost:3000"]

# ── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://eval:eval_secret@localhost:5432/eval_engine
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_CACHE_TTL=300

# ── Celery ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=8
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_HARD_TIME_LIMIT=600

# ── S3 / MinIO ──────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=eval-engine
S3_REGION=us-east-1
S3_PRESIGNED_URL_EXPIRY=3600

# ── Observability ────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── OpenTelemetry ────────────────────────────────────────
OTEL_ENABLED=true
OTEL_SERVICE_NAME=eval-engine
OTEL_EXPORTER=jaeger
OTEL_ENDPOINT=http://localhost:4317
OTEL_SAMPLE_RATE=1.0
